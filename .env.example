DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_events
DB_USER=app_user
DB_PASSWORD=app_password
# DDL-only credentials for migrations - never used by the running app for request-serving queries.
DB_ADMIN_USER=admin_user
DB_ADMIN_PASSWORD=admin_password
DB_SSL=false
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development
POSTGRES_ADMIN_PASSWORD=admin_password

# Auth: AUTH_MODE=oidc (default, production) requires AUTH_JWKS_URI/AUTH_ISSUER/AUTH_AUDIENCE.
# AUTH_MODE=local (dev/test only) requires AUTH_LOCAL_SECRET and exposes an unauthenticated
# dev-token endpoint. It is refused at startup unless NODE_ENV is explicitly "development" or
# "test". This is a DEVELOPMENT template - never deploy it verbatim to a real environment; for
# staging/production set AUTH_MODE=oidc and NODE_ENV=production.
AUTH_MODE=local
AUTH_LOCAL_SECRET=replace-with-a-long-random-dev-only-secret
AUTH_JWKS_URI=
AUTH_ISSUER=
AUTH_AUDIENCE=

# SCIM: required in all modes, no default value permitted.
SCIM_BEARER_TOKEN=replace-with-a-long-random-scim-bearer-token
