DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_events
DB_USER=app_user
DB_PASSWORD=app_password
# DDL-only credentials for migrations - never used by the running app for request-serving queries.
DB_ADMIN_USER=admin_user
DB_ADMIN_PASSWORD=admin_password
DB_SSL=false
# Used only by deploy/compose/docker-compose.yml's postgres-standby service (pg_basebackup).
REPLICATION_PASSWORD=replication_password
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development
POSTGRES_ADMIN_PASSWORD=admin_password

# Auth: AUTH_MODE=oidc (default, production) requires AUTH_JWKS_URI/AUTH_ISSUER/AUTH_AUDIENCE.
# AUTH_MODE=local (dev/test only) requires AUTH_LOCAL_SECRET and exposes an unauthenticated
# dev-token endpoint. It is refused at startup unless NODE_ENV is explicitly "development" or
# "test". This is a DEVELOPMENT template - never deploy it verbatim to a real environment; for
# staging/production set AUTH_MODE=oidc and NODE_ENV=production.
AUTH_MODE=local
AUTH_LOCAL_SECRET=replace-with-a-long-random-dev-only-secret
AUTH_JWKS_URI=
AUTH_ISSUER=
AUTH_AUDIENCE=

# SCIM: required in all modes, no default value permitted.
SCIM_BEARER_TOKEN=replace-with-a-long-random-scim-bearer-token

# Audit: non-disableable statutory edit log (FR-AC-13).
# AUDIT_LOG_ENABLED must be "true" - the application refuses to start if set to "false".
# AUDIT_LOG_RETENTION_YEARS controls how long entries stay online before archival (default 8).
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_YEARS=8

# Edge PWA and PowerSync: required for Story 1.8 offline shell and sync layer.
EDGE_SITE_NAME=Pilot Gate Site
POWERSYNC_URL=/powersync
POWERSYNC_TOKEN_ISSUER=inventory-edge
POWERSYNC_TOKEN_AUDIENCE=powersync
POWERSYNC_TOKEN_SECRET=replace-with-a-long-random-powersync-token-secret
POWERSYNC_TOKEN_TTL=15m
POWERSYNC_SOURCE_PASSWORD=svc_powersync_password

# ERP inbound reference projections (Story 2.9, INT-ERP-01). A projection is stale when its
# last successful sync is older than this many milliseconds (default 900000 = 15 minutes).
ERP_SYNC_FRESHNESS_MS=900000
